# Copy to .env.local and fill in. Do NOT commit real values.

# Liquid coverage API key (static key shipped by coverage.za.liquid.tech).
LIQUID_API_KEY=

# Google Maps Platform key — enables Google geocoding + Places autocomplete.
# Leave blank to use the free OpenStreetMap Nominatim fallback for geocoding.
GOOGLE_MAPS_API_KEY=

# Axxess Reseller/Business Partner API.
# Base: test = https://apitest.axxess.co.za , live = https://rcp.axxess.co.za
AXXESS_API_BASE=https://apitest.axxess.co.za
# Reseller-wide HTTP Basic auth (provided by Axxess).
AXXESS_BASIC_USER=
AXXESS_BASIC_PASS=
# Your Control Panel login (used by getSession). On the test system this is your
# apitest.axxess.co.za account; sign up at /signup.php if you don't have one.
AXXESS_CP_USER=
AXXESS_CP_PASS=

# "true" enables interim headless-browser scrapers (Herotel, later MTN/Vox).
# Needs playwright installed. Keep unset in production until a browser host exists.
ENABLE_HEADLESS_SCRAPERS=
